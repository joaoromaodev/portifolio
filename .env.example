# Live-widget API credentials (server-only — never expose to the client).
# Each widget proxies through a Next.js Route Handler in /app/api/* (DESIGN.md §4/§11).
# Copy to .env.local and fill in. Widgets fall back to static snapshots when unset.

# GitHub — read-only token for the contributions/heatmap widget
GITHUB_TOKEN=

# Spotify — "now playing" (OAuth refresh-token flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Steam — recently played (public profile)
STEAM_API_KEY=
STEAM_ID=

# Anthropic — "Ask my portfolio" chatbot (Claude Haiku 4.5, claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Weather (Belém) uses Open-Meteo — no key required.
